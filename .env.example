# Kakao Maps API - Get your key from: https://developers.kakao.com/
KAKAO_REST_API_KEY=your_kakao_api_key_here

# Korea National Oil Corporation (Opinet) API - Get from: https://www.opinet.co.kr/
OPINET_API_KEY=your_opinet_api_key_here

# MCP Server Configuration (Optional - defaults provided)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
